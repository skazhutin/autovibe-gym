# Copy this file to .env and fill in your values
# Never commit .env to git

# ── Local vLLM server (H200) ──────────────────────────────────────────────
LLM_BASE_URL=http://<server-ip>:8000/v1
LLM_API_KEY=local
LLM_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct

# ── Groq (free tier, no proxy needed) ───────────────────────────────────
# Get key at: https://console.groq.com/keys
# LLM_MODEL=groq/llama-3.3-70b-versatile
# GROQ_API_KEY=gsk_...

# ── Cloud APIs (optional fallback) ───────────────────────────────────────
# OpenAI
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o

# Anthropic (direct, no proxy)
# LLM_MODEL=anthropic/claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-...

# ── MLflow ────────────────────────────────────────────────────────────────
# Run: mlflow server --host 0.0.0.0 --port 5000
MLFLOW_TRACKING_URI=http://<server-ip>:5000
