# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Default: OpenAI-compatible API (local vLLM, OpenAI, LiteLLM proxies).
# If LLM_PROVIDER is omitted, "openai" is used.
LLM_PROVIDER=openai
LLM_BASE_URL=http://<server-ip>:8000/v1
LLM_API_KEY=local
LLM_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct

# Google AI Studio / Gemini API for laptop/local cloud usage.
# LLM_PROVIDER=google
# GEMINI_API_KEY=...
# LLM_MODEL=gemini-2.5-flash

# LiteLLM direct SDK mode, e.g. Groq or Anthropic without a proxy.
# LLM_PROVIDER=litellm
# LLM_MODEL=groq/llama-3.3-70b-versatile
# GROQ_API_KEY=gsk_...
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI cloud API.
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o

# Anthropic via LiteLLM proxy.
# LLM_PROVIDER=openai
# LLM_BASE_URL=http://localhost:4000/v1
# LLM_API_KEY=sk-ant-...
# LLM_MODEL=claude-sonnet-4-6

# Code execution sandbox.
# Build once: docker build -f Dockerfile.sandbox -t autovibe-gym-sandbox:latest .
AUTOVIBE_EXECUTOR_BACKEND=docker
AUTOVIBE_SANDBOX_IMAGE=autovibe-gym-sandbox:latest
AUTOVIBE_SANDBOX_MEMORY_MB=2048
AUTOVIBE_SANDBOX_CPUS=1
AUTOVIBE_SANDBOX_PIDS_LIMIT=128

# Jupyter kernel backend for NotebookGymEnv.
# "local" runs ipykernel in the host process (default).
# "docker" runs each kernel in an isolated container (requires Docker + sandbox image).
AUTOVIBE_KERNEL_BACKEND=local
# AUTOVIBE_KERNEL_BACKEND=docker
AUTOVIBE_KERNEL_MEMORY_MB=2048
# AUTOVIBE_KERNEL_CPUS=1
# AUTOVIBE_KERNEL_PIDS_LIMIT=512
# AUTOVIBE_KERNEL_NETWORK=autovibe-kernels

# MLflow.
# If omitted, runners and compare both use local sqlite:///mlflow.db.
# To use an existing MLflow server, uncomment and set a real URL:
# MLFLOW_TRACKING_URI=http://127.0.0.1:5000
