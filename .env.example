# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Model names, providers, and endpoint URLs live in the shared model registry:
#   python -m experiments.models list
#   python -m experiments.models add --name deepseek-v4-flash \
#     --provider "OpenAI-совместимый" --base-url http://host:8000/v1
#   python -m experiments.models add --name gemini-2.5-flash --provider Gemini
#
# .env should not contain LLM model settings or LLM API keys.
# Store per-model keys in the dashboard Models page or with:
#   python -m experiments.models add ... --api-key <secret>

# Code execution sandbox.
# Build once: docker build -f Dockerfile.sandbox -t autovibe-gym-sandbox:latest .
AUTOVIBE_EXECUTOR_BACKEND=docker
AUTOVIBE_SANDBOX_IMAGE=autovibe-gym-sandbox:latest
AUTOVIBE_SANDBOX_MEMORY_MB=2048
AUTOVIBE_SANDBOX_CPUS=1
AUTOVIBE_SANDBOX_PIDS_LIMIT=128

# Jupyter kernel backend for NotebookGymEnv.
# "local" runs ipykernel in the host process (default).
# "docker" runs each kernel in an isolated container (requires Docker + sandbox image).
AUTOVIBE_KERNEL_BACKEND=local
# AUTOVIBE_KERNEL_BACKEND=docker
AUTOVIBE_KERNEL_MEMORY_MB=2048
# AUTOVIBE_KERNEL_CPUS=1
# AUTOVIBE_KERNEL_PIDS_LIMIT=512
# AUTOVIBE_KERNEL_NETWORK=autovibe-kernels

# MLflow.
# If omitted, runners and compare both use local sqlite:///mlflow.db.
# To use an existing MLflow server, uncomment and set a real URL:
# MLFLOW_TRACKING_URI=http://127.0.0.1:5000
