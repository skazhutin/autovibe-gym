# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
*.egg
venv/
.venv/
env/

# Environment & secrets
.env
.env.local
.env.*.local
*.key

# MLflow tracking — generated experiment data
mlruns/

# Generic outputs/logs
runs/
outputs/
results/
*.log
*.jsonl

# Keep dataset configs/docs; ignore generated tables by default
# and selectively unignore example dataset artifacts.
datasets/**/*.csv
datasets/**/*.parquet
datasets/**/*.xlsx
datasets/**/*.json
!datasets/README.md
!datasets/*/config.json
!datasets/*/raw_data/.gitkeep

# AI agent artifacts
.claude/
memory/
.codex/
.cursor/
.aider*

# Jupyter
.ipynb_checkpoints/
*.ipynb

# IDE/OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Local raw dataset archives (manual upload, not committed)
datasets/*/raw_data/*.zip
