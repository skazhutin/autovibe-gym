{
  "name": "phiusiil_phishing",
  "suite": "example_datasets",
  "source": {
    "type": "local_file",
    "provider": "example dataset supplied by project team",
    "reference": "phiusiil_phishing",
    "license": "unknown"
  },
  "raw_data": {
    "files": [
      "PhiUSIIL_Phishing_URL_Dataset.csv"
    ],
    "format": "csv",
    "read_options": {
      "sep": ",",
      "encoding": "utf-8"
    }
  },
  "task": {
    "type": "classification",
    "target_col": "label",
    "metric": "f1_macro"
  },
  "split": {
    "strategy": "stratified_random",
    "seed": 42,
    "train_fraction": 0.7,
    "val_fraction": 0.15,
    "test_fraction": 0.15
  },
  "preparation": {
    "sampling": {
      "allowed": true,
      "strategy": "stratified_random",
      "seed": 42
    },
    "drop_columns": ["FILENAME", "URL", "Domain", "TLD", "Title"]
  },
  "role": "large_mixed_features_suspicious_columns",
  "notes": {
    "contamination_risk": "reduced_vs_canonical_benchmarks",
    "inspect_suspicious_columns": true,
    "suspicious_columns": ["URLSimilarityIndex"],
    "drop_reason": "FILENAME/URL/Domain/TLD/Title are non-numeric identifiers that would cause dtype errors and may directly encode the label"
  }
}